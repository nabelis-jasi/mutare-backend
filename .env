# Database connection (PostgreSQL with PostGIS)
DATABASE_URL=postgresql://postgres:12345@localhost:5432/blue

# JWT security – CHANGE THIS to a long random string
SECRET_KEY=replace_this_with_a_secure_random_key_at_least_32_chars

# CORS – add your frontend URLs (React dev server, production)
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000,https://yourfrontend.com

# Environment: development or production
ENVIRONMENT=development

# Port for FastAPI (default 5000)
PORT=5000

# Optional: additional frontend URL (automatically added to ALLOWED_ORIGINS by the code)
FRONTEND_URL=http://localhost:5173
